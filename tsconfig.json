{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@boot/*": ["src/boot/*"],
      "@game/*": ["src/game/*"],
      "@skia/*": ["src/skia/*"],
      "@ui/*": ["src/ui/*"]
    },
    "types": ["jest"]
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["**/node_modules", "**/Pods"]
}
